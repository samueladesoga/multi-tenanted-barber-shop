# Secrets pulled from the local environment at deploy time.
# DO NOT hard-code values here — this file is safe to commit.
# Set these variables in your shell (or CI) before running `kamal deploy`.
#
# Quickstart: copy these exports into ~/.barberapp_secrets and `source` them before deploying.

# Rails master key — never commit config/master.key
RAILS_MASTER_KEY=$(cat config/master.key)

# Docker Hub password / access token
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# PostgreSQL
# Format: postgresql://barberapp:PASSWORD@127.0.0.1:5432/barberapp_production
DATABASE_URL=$DATABASE_URL
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# Twilio SMS (leave blank to disable SMS — SmsService will log instead)
TWILIO_ACCOUNT_SID=$TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=$TWILIO_AUTH_TOKEN
TWILIO_FROM=$TWILIO_FROM

# SMTP — e.g. Postmark, Mailgun, or any transactional provider
SMTP_ADDRESS=$SMTP_ADDRESS
SMTP_USERNAME=$SMTP_USERNAME
SMTP_PASSWORD=$SMTP_PASSWORD
