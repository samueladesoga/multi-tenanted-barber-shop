<div class="max-w-lg mx-auto space-y-6">
  <div class="text-center">
    <h1 class="text-2xl font-bold text-gray-900"><%= current_salon.name %></h1>
    <p class="text-gray-500 mt-1">Book an appointment</p>
  </div>

  <% unless @customer %>
    <!-- Step 1: Find customer -->
    <div class="bg-white shadow rounded-lg p-6 space-y-5">
      <h2 class="font-semibold text-gray-700">Find Your Account</h2>

      <div class="flex gap-2">
        <%= form_with url: new_booking_path, method: :get, local: true, class: "flex-1 flex gap-2" do |f| %>
          <%= f.telephone_field :phone, value: params[:phone], placeholder: "Your phone number",
              class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400" %>
          <%= f.submit "Find", class: "bg-amber-500 hover:bg-amber-600 text-white py-2 px-4 rounded-lg cursor-pointer text-sm font-medium" %>
        <% end %>
      </div>

      <div class="relative flex items-center">
        <div class="flex-1 border-t border-gray-200"></div>
        <span class="mx-3 text-sm text-gray-400">or search by name</span>
        <div class="flex-1 border-t border-gray-200"></div>
      </div>

      <div class="flex gap-2">
        <%= form_with url: new_booking_path, method: :get, local: true, class: "flex-1 flex gap-2" do |f| %>
          <%= f.text_field :name, value: params[:name], placeholder: "Your name",
              class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400" %>
          <%= f.submit "Search", class: "bg-gray-700 hover:bg-gray-800 text-white py-2 px-4 rounded-lg cursor-pointer text-sm" %>
        <% end %>
      </div>

      <% if @not_found %>
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 space-y-3">
          <p class="text-sm text-amber-800">Phone number not found. Enter your details to register and book.</p>
          <%= form_with url: bookings_path, local: true, class: "space-y-3" do |f| %>
            <input type="hidden" name="booking[phone_number]" value="<%= params[:phone] %>">
            <div>
              <%= f.label :name, "Your Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <input name="booking[name]" type="text" required
                     class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400"
                     placeholder="Your full name">
            </div>
            <%= render "booking_service_slot_form", f: f, services: @services %>
          <% end %>
        </div>
      <% end %>

      <% if @found_customers.present? %>
        <div class="border border-gray-200 rounded-lg divide-y divide-gray-100">
          <% @found_customers.each do |c| %>
            <%= link_to new_booking_path(customer_id: c.id),
                class: "flex items-center justify-between px-4 py-3 hover:bg-amber-50 transition-colors" do %>
              <div>
                <span class="font-medium text-gray-900"><%= c.name %></span>
                <span class="text-gray-400 text-sm ml-2"><%= c.phone_number %></span>
              </div>
              <span class="text-amber-500 text-sm font-medium">Book &rarr;</span>
            <% end %>
          <% end %>
        </div>
      <% elsif params[:name].present? && @found_customers&.empty? %>
        <p class="text-sm text-gray-400">No results. Try your phone number instead.</p>
      <% end %>
    </div>
  <% end %>

  <% if @customer %>
    <!-- Step 2: Select service and slot -->
    <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3">
      <p class="font-semibold text-gray-900"><%= @customer.name %></p>
      <p class="text-sm text-gray-500"><%= @customer.phone_number %></p>
    </div>

    <%= form_with url: bookings_path, local: true, class: "bg-white shadow rounded-lg p-6 space-y-5" do |f| %>
      <input type="hidden" name="booking[customer_id]" value="<%= @customer.id %>">
      <%= render "booking_service_slot_form", f: f, services: @services %>
    <% end %>
  <% end %>
</div>
