<%= content_for :head do %>
  <style>
    @media print {
      /* Hide everything except the print card */
      nav, .no-print { display: none !important; }
      main { padding: 0 !important; }
      body { background: white !important; }
      .print-card {
        box-shadow: none !important;
        border: 1px solid #e5e7eb;
        max-width: 300px;
        margin: 0 auto;
        page-break-inside: avoid;
      }
    }
  </style>
<% end %>

<div class="max-w-sm mx-auto text-center space-y-6" data-controller="print">
  <!-- Screen-only heading -->
  <div class="no-print">
    <h1 class="text-2xl font-bold text-gray-900"><%= @customer.name %></h1>
    <p class="text-gray-500 text-sm mt-1">
      <%= current_salon.name %> &bull; <%= @customer.visits_count %> visits
    </p>
  </div>

  <!-- Print card — shown on screen and in print -->
  <div class="print-card bg-white shadow rounded-xl p-6 inline-block">
    <p class="font-bold text-lg text-gray-900 mb-1"><%= @customer.name %></p>
    <p class="text-xs text-gray-400 mb-4"><%= current_salon.name %></p>
    <%= @customer.qr_code_svg(scan_qr_url(@customer.qr_token)).html_safe %>
    <p class="text-xs text-gray-400 font-mono mt-3 break-all"><%= @customer.qr_token %></p>
    <p class="text-xs text-gray-500 mt-2">Show this at every visit to earn your free cut.</p>
  </div>

  <!-- Loyalty progress (screen only) -->
  <% if @customer.visits_count > 0 %>
    <div class="no-print bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm">
      <% if @customer.next_visit_free? %>
        <p class="text-amber-700 font-semibold">Next visit is FREE!</p>
      <% else %>
        <p class="text-amber-700">
          <%= @customer.visits_until_free %> more visit<%= @customer.visits_until_free == 1 ? "" : "s" %>
          until a free cut
        </p>
      <% end %>
    </div>
  <% end %>

  <!-- Actions (screen only) -->
  <div class="no-print flex justify-center gap-3 flex-wrap">
    <%= link_to "Check In Now", new_visit_path(customer_id: @customer.id),
        class: "bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-5 rounded-lg text-sm transition-colors" %>
    <button data-action="print#now"
            class="bg-gray-800 hover:bg-gray-700 text-white py-2 px-5 rounded-lg text-sm transition-colors">
      Print QR Code
    </button>
    <%= link_to "Back to Customer", customer_path(@customer),
        class: "text-gray-500 hover:text-gray-700 py-2 px-4 text-sm" %>
  </div>

  <!-- Share section (screen only) -->
  <div class="no-print border-t border-gray-200 pt-4 space-y-3">
    <p class="text-sm font-medium text-gray-500 text-center">Share loyalty card with customer</p>
    <div class="flex justify-center gap-3 flex-wrap">
      <%# WhatsApp — opens a pre-filled message to the customer's number %>
      <% whatsapp_number = @customer.phone_number.gsub(/\D/, "") %>
      <% card_url = loyalty_card_url(@customer.qr_token) %>
      <% whatsapp_message = "Hi #{@customer.name}! Here is your loyalty card for #{current_salon.name}. Show this at every visit to earn your free cut: #{card_url}" %>
      <%= link_to "https://wa.me/#{whatsapp_number}?text=#{ERB::Util.url_encode(whatsapp_message)}",
          class: "inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-semibold py-2 px-5 rounded-lg text-sm transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        WhatsApp
      <% end %>

      <%# Email — only shown when customer has an email address %>
      <% if @customer.email.present? %>
        <%= button_to share_loyalty_card_customer_path(@customer), method: :post,
            class: "inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-5 rounded-lg text-sm transition-colors cursor-pointer border-0" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Send Email
        <% end %>
      <% else %>
        <span class="inline-flex items-center gap-2 bg-gray-200 text-gray-400 font-semibold py-2 px-5 rounded-lg text-sm cursor-not-allowed"
              title="No email address on file">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Send Email
        </span>
      <% end %>
    </div>
  </div>
</div>
