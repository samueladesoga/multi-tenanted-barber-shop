<div class="space-y-6">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @customer.name %></h1>
      <p class="text-gray-500"><%= @customer.phone_number %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_customer_path(@customer), class: "text-sm text-gray-500 hover:text-gray-700 border border-gray-300 rounded-lg py-2 px-4" %>
      <%= link_to "Check In", new_visit_path(customer_id: @customer.id),
          class: "bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors" %>
    </div>
  </div>

  <!-- Loyalty progress -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="font-semibold text-gray-700 mb-3">Loyalty Status</h2>
    <div class="flex items-center gap-6">
      <div class="text-center">
        <p class="text-3xl font-bold text-amber-500"><%= @customer.visits_count %></p>
        <p class="text-xs text-gray-400">Total visits</p>
      </div>
      <div class="flex-1">
        <div class="flex justify-between text-xs text-gray-500 mb-1">
          <span>Progress to free cut</span>
          <span><%= @customer.visits_count % current_salon.loyalty_threshold %>/<%= current_salon.loyalty_threshold %></span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-3">
          <% progress = (@customer.visits_count % current_salon.loyalty_threshold).to_f / current_salon.loyalty_threshold * 100 %>
          <div class="bg-amber-400 h-3 rounded-full transition-all" style="width: <%= [progress, 100].min %>%"></div>
        </div>
        <% if @customer.visits_until_free == 1 %>
          <p class="text-amber-600 font-semibold text-sm mt-2">Next visit is FREE!</p>
        <% else %>
          <p class="text-gray-400 text-xs mt-1"><%= @customer.visits_until_free %> visits until free cut</p>
        <% end %>
      </div>
      <%= link_to "View QR Code", qr_code_customer_path(@customer), class: "text-sm text-amber-600 hover:underline" %>
    </div>
  </div>

  <!-- Customer details -->
  <div class="bg-white shadow rounded-lg p-6 grid grid-cols-2 gap-4 text-sm">
    <div><span class="text-gray-400">Email:</span> <%= @customer.email.presence || "—" %></div>
    <div><span class="text-gray-400">Area:</span> <%= @customer.area.presence || "—" %></div>
    <div><span class="text-gray-400">State:</span> <%= @customer.state.presence || "—" %></div>
    <div><span class="text-gray-400">Member since:</span> <%= @customer.created_at.strftime("%d %b %Y") %></div>
  </div>

  <!-- Visit history -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-800">Visit History</h2>
    </div>
    <% if @recent_visits.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Service</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @recent_visits.each do |visit| %>
            <tr>
              <td class="px-6 py-3 text-sm text-gray-600"><%= visit.visited_at.strftime("%d %b %Y, %H:%M") %></td>
              <td class="px-6 py-3 text-sm text-gray-800"><%= visit.service.name %></td>
              <td class="px-6 py-3 text-sm">
                <%= format_currency(visit.price_charged) %>
                <% if visit.is_free? %>
                  <span class="ml-1 text-xs bg-amber-100 text-amber-700 px-1 rounded">FREE</span>
                <% elsif visit.discounted? %>
                  <span class="ml-1 text-xs text-gray-400">(discounted from <%= format_currency(visit.service.base_price) %>)</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-6 py-8 text-center text-gray-400">No visits recorded yet.</p>
    <% end %>
  </div>
</div>
