<div class="space-y-8">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-400"><%= Date.today.strftime("%A, %d %B %Y") %></p>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white shadow rounded-lg p-5">
      <p class="text-sm text-gray-500">Visits Today</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= @visits_today %></p>
    </div>
    <div class="bg-white shadow rounded-lg p-5">
      <p class="text-sm text-gray-500">Revenue Today</p>
      <p class="text-2xl font-bold text-green-600 mt-1"><%= format_currency(@revenue_today) %></p>
    </div>
    <div class="bg-white shadow rounded-lg p-5">
      <p class="text-sm text-gray-500">Visits This Month</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= @visits_this_month %></p>
    </div>
    <div class="bg-white shadow rounded-lg p-5">
      <p class="text-sm text-gray-500">Revenue This Month</p>
      <p class="text-2xl font-bold text-green-600 mt-1"><%= format_currency(@revenue_this_month) %></p>
      <% if @revenue_change %>
        <p class="text-xs mt-1 <%= @revenue_change >= 0 ? 'text-green-500' : 'text-red-500' %>">
          <%= @revenue_change >= 0 ? "▲" : "▼" %> <%= @revenue_change.abs %>% vs last month
        </p>
      <% end %>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="flex flex-wrap gap-3">
    <%= link_to "Check In Customer", new_visit_path,
        class: "bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-5 rounded-lg transition-colors" %>
    <%= link_to "Register Customer", new_customer_path,
        class: "bg-gray-800 hover:bg-gray-700 text-white font-semibold py-2 px-5 rounded-lg transition-colors" %>
    <%= link_to "Book Appointment", new_appointment_path,
        class: "bg-gray-800 hover:bg-gray-700 text-white font-semibold py-2 px-5 rounded-lg transition-colors" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Today's appointments -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-800">Today's Appointments</h2>
        <%= link_to "View all", appointments_path, class: "text-xs text-amber-500 hover:underline" %>
      </div>
      <% if @appointments_today.any? %>
        <ul class="divide-y divide-gray-100">
          <% @appointments_today.each do |appt| %>
            <li class="px-6 py-3 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= appt.customer.name %></p>
                <p class="text-xs text-gray-400">
                  <%= appt.scheduled_at.strftime("%H:%M") %>
                  <% if appt.service %> &bull; <%= appt.service.name %><% end %>
                </p>
              </div>
              <% if appt.pending? %>
                <span class="text-xs bg-yellow-100 text-yellow-700 font-medium px-2 py-0.5 rounded">Pending</span>
              <% else %>
                <span class="text-xs bg-green-100 text-green-700 font-medium px-2 py-0.5 rounded">Confirmed</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="px-6 py-8 text-sm text-center text-gray-400">No appointments scheduled today.</p>
      <% end %>
    </div>

    <!-- Customers near free cut -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-800">Ready for Free Cut</h2>
        <span class="text-xs text-gray-400">One visit away</span>
      </div>
      <% if @near_milestone.any? %>
        <ul class="divide-y divide-gray-100">
          <% @near_milestone.each do |customer| %>
            <li class="px-6 py-3 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= customer.name %></p>
                <p class="text-xs text-gray-400"><%= customer.phone_number %> &bull; <%= customer.visits_count %> visits</p>
              </div>
              <%= link_to "Check in", new_visit_path(customer_id: customer.id),
                  class: "text-xs bg-amber-500 hover:bg-amber-600 text-white font-medium px-3 py-1 rounded transition-colors" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="px-6 py-8 text-sm text-center text-gray-400">No customers near their free cut right now.</p>
      <% end %>
    </div>
  </div>

  <!-- Recent visits -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="font-semibold text-gray-800">Recent Visits</h2>
      <%= link_to "View all", visits_path, class: "text-xs text-amber-500 hover:underline" %>
    </div>
    <% if @recent_visits.any? %>
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Service</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Time</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_visits.each do |visit| %>
            <tr>
              <td class="px-6 py-3 text-sm font-medium text-gray-900"><%= visit.customer.name %></td>
              <td class="px-6 py-3 text-sm text-gray-600"><%= visit.service.name %></td>
              <td class="px-6 py-3 text-sm text-gray-600">
                <%= format_currency(visit.price_charged) %>
                <% if visit.is_free? %>
                  <span class="ml-1 text-xs bg-amber-100 text-amber-700 px-1 rounded">FREE</span>
                <% end %>
              </td>
              <td class="px-6 py-3 text-sm text-gray-400"><%= visit.visited_at.strftime("%H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-6 py-8 text-center text-sm text-gray-400">No visits yet today.</p>
    <% end %>
  </div>
</div>
