<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || (current_salon ? "#{current_salon.name} | BarberApp" : "BarberApp") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <% if current_salon %>
      <nav class="bg-gray-900 text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <div class="flex items-center space-x-8">
              <span class="font-bold text-xl text-amber-400"><%= current_salon.name %></span>
              <div class="flex space-x-4">
                <%= link_to "Dashboard", dashboard_path, class: nav_link_class("dashboard") %>
                <%= link_to "Customers", customers_path, class: nav_link_class("customers") %>
                <%= link_to "Visits", visits_path, class: nav_link_class("visits") %>
                <%= link_to "Appointments", appointments_path, class: nav_link_class("appointments") %>
                <%= link_to "Services", services_path, class: nav_link_class("services") %>
                <%= link_to "Expenses", expenses_path, class: nav_link_class("expenses") %>
                <%= link_to "Reports", reports_path, class: nav_link_class("reports") %>
                <% if Current.staff&.owner? %>
                  <%= link_to "Team", staffs_path, class: nav_link_class("staffs") %>
                  <%= link_to "Settings", edit_settings_path, class: nav_link_class("settings") %>
                <% end %>
              </div>
            </div>
            <div class="flex items-center space-x-4">
              <% if staff_signed_in? %>
                <span class="text-sm text-gray-300"><%= current_staff.name %></span>
                <%= link_to "Sign out", destroy_staff_session_path, data: { turbo_method: :delete },
                    class: "text-sm text-gray-300 hover:text-white" %>
              <% end %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <% if notice.present? %>
        <div class="mb-4 bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
