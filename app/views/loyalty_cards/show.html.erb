<div class="min-h-screen bg-gray-900 flex flex-col items-center justify-center px-4 py-12">

  <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-sm w-full text-center space-y-5">
    <div>
      <p class="text-xs font-semibold text-amber-500 uppercase tracking-widest mb-1"><%= @salon.name %></p>
      <h1 class="text-2xl font-bold text-gray-900"><%= @customer.name %></h1>
      <p class="text-sm text-gray-400 mt-1">Loyalty Card</p>
    </div>

    <div class="flex justify-center">
      <%= qr_code_svg_tag(@customer, scan_qr_url(@customer.qr_token)) %>
    </div>

    <p class="text-xs text-gray-400 font-mono break-all"><%= @customer.qr_token %></p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm">
      <% if @customer.loyalty_milestone? %>
        <p class="text-amber-700 font-bold">Your next visit is FREE!</p>
      <% elsif @customer.next_visit_free? %>
        <p class="text-amber-700 font-semibold">Next visit is FREE!</p>
      <% else %>
        <p class="text-amber-700">
          <span class="font-bold"><%= @customer.visits_until_free %></span>
          more visit<%= @customer.visits_until_free == 1 ? "" : "s" %> until a free cut
        </p>
      <% end %>
      <p class="text-gray-400 text-xs mt-1"><%= @customer.visits_count %> total visits</p>
    </div>

    <p class="text-xs text-gray-400">Show this QR code at every visit to earn your free cut.</p>

    <%= link_to "Book an Appointment", new_booking_path,
        class: "block w-full bg-amber-500 hover:bg-amber-600 text-white font-semibold py-3 rounded-xl transition-colors" %>
  </div>

  <p class="text-gray-600 text-xs mt-6">Powered by <span class="text-amber-500">BarberApp</span></p>
</div>
