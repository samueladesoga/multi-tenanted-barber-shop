<div class="max-w-xl mx-auto">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Register Your Salon</h1>
    <p class="text-gray-500 mt-2">Get set up in minutes</p>
  </div>

  <%= form_with model: @salon, url: salon_registrations_path, local: true, class: "bg-white shadow rounded-lg p-8 space-y-6" do |f| %>
    <% if @salon.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
          <% @salon.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <h2 class="text-lg font-semibold text-gray-700 border-b pb-2">Salon Details</h2>

    <div>
      <%= f.label :name, "Salon Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400", placeholder: "Cuts by Joe" %>
    </div>

    <div>
      <%= f.label :subdomain, "Subdomain", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="flex items-center">
        <%= f.text_field :subdomain, class: "flex-1 border border-gray-300 rounded-l-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400", placeholder: "cuts-by-joe" %>
        <span class="bg-gray-100 border border-l-0 border-gray-300 rounded-r-lg px-3 py-2 text-gray-500 text-sm">.barberapp.club</span>
      </div>
      <p class="text-xs text-gray-400 mt-1">Lowercase letters, numbers, and hyphens only</p>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :loyalty_threshold, "Free cut after X visits", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :loyalty_threshold, value: 10, min: 1, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400" %>
      </div>
      <div>
        <%= f.label :chair_count, "Number of chairs", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :chair_count, value: 1, min: 1, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400" %>
      </div>
    </div>

    <h2 class="text-lg font-semibold text-gray-700 border-b pb-2 pt-2">Owner Account</h2>

    <div>
      <%= f.label :owner_name, "Your Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :owner_name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400", placeholder: "Joe Smith" %>
    </div>

    <div>
      <%= f.label :owner_email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :owner_email, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400", placeholder: "joe@example.com" %>
    </div>

    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400 focus:border-amber-400" %>
    </div>

    <%= f.submit "Create My Salon", class: "w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-4 rounded-lg transition-colors cursor-pointer" %>
  <% end %>
</div>
