<div class="space-y-6">
  <h1 class="text-2xl font-bold text-gray-900">Reports</h1>

  <%= render "report_nav",
      selected_month: @selected_month,
      prev_month: @prev_month,
      next_month: @next_month,
      is_future: @is_future %>

  <% if @discounted_visit_count > 0 %>
    <!-- Summary cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-white shadow rounded-lg p-5 text-center">
        <p class="text-sm text-gray-500">Total Discounted</p>
        <p class="text-2xl font-bold text-amber-600"><%= format_currency(@total_discount_amount) %></p>
        <p class="text-xs text-gray-400 mt-1">
          <%= @total_revenue > 0 ? "#{(@total_discount_amount / @total_revenue * 100).round(1)}% of gross revenue" : "—" %>
        </p>
      </div>
      <div class="bg-white shadow rounded-lg p-5 text-center">
        <p class="text-sm text-gray-500">Discounted Visits</p>
        <p class="text-2xl font-bold text-gray-800"><%= @discounted_visit_count %></p>
      </div>
      <div class="bg-white shadow rounded-lg p-5 text-center">
        <p class="text-sm text-gray-500">Avg Discount per Visit</p>
        <p class="text-2xl font-bold text-gray-700">
          <%= @discounted_visit_count > 0 ? format_currency(@total_discount_amount / @discounted_visit_count) : "—" %>
        </p>
      </div>
    </div>

    <!-- Daily discount trend -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Discount Trend</h2>
      <%= line_chart @daily_discounts,
          colors:  ["#f59e0b"],
          library: { scales: { y: { beginAtZero: true } } } %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Discounts by service -->
      <div class="bg-white shadow rounded-lg p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">By Service</h2>
        <% if @discount_by_service.any? %>
          <%= bar_chart @discount_by_service.to_h, colors: ["#f59e0b"], library: { indexAxis: "y" } %>
          <table class="min-w-full mt-4 text-sm divide-y divide-gray-100">
            <% @discount_by_service.each do |service, amount| %>
              <tr class="flex justify-between py-2">
                <td class="text-gray-700"><%= service %></td>
                <td class="font-semibold text-amber-600"><%= format_currency(amount) %></td>
              </tr>
            <% end %>
          </table>
        <% end %>
      </div>

      <!-- Discounts by staff -->
      <div class="bg-white shadow rounded-lg p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">By Staff Member</h2>
        <% if @discount_by_staff.any? %>
          <%= bar_chart @discount_by_staff.to_h, colors: ["#3b82f6"], library: { indexAxis: "y" } %>
          <table class="min-w-full mt-4 text-sm divide-y divide-gray-100">
            <% @discount_by_staff.each do |name, amount| %>
              <tr class="flex justify-between py-2">
                <td class="text-gray-700"><%= name %></td>
                <td class="font-semibold text-blue-600"><%= format_currency(amount) %></td>
              </tr>
            <% end %>
          </table>
        <% else %>
          <p class="text-sm text-gray-400">No staff assignment data available.</p>
        <% end %>
      </div>
    </div>

    <!-- Discount reasons -->
    <% if @discount_reasons.any? %>
      <div class="bg-white shadow rounded-lg p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">Discount Reasons</h2>
        <div class="space-y-3">
          <% max_count = @discount_reasons.first[1].to_f %>
          <% @discount_reasons.each do |reason, count| %>
            <div class="flex items-center gap-3">
              <span class="text-sm text-gray-700 w-48 truncate"><%= reason %></span>
              <div class="flex-1 bg-gray-100 rounded-full h-2">
                <div class="bg-amber-400 h-2 rounded-full"
                     style="width: <%= (count / max_count * 100).round %>%"></div>
              </div>
              <span class="text-sm font-medium text-gray-600 w-8 text-right"><%= count %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  <% else %>
    <div class="bg-white shadow rounded-lg px-6 py-16 text-center text-gray-400">
      No discounts were given in <%= @selected_month.strftime("%B %Y") %>.
    </div>
  <% end %>
</div>
