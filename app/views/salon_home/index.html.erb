<div class="min-h-screen bg-gray-900 flex flex-col">

  <!-- Header -->
  <header class="flex items-center justify-between px-6 py-4 max-w-5xl mx-auto w-full">
    <h1 class="text-2xl font-bold text-amber-400"><%= current_salon.name %></h1>
    <%= link_to "Staff Login", new_staff_session_path,
        class: "text-sm text-gray-300 hover:text-white border border-gray-600 hover:border-gray-400 px-4 py-2 rounded-lg transition-colors" %>
  </header>

  <!-- Hero -->
  <main class="flex-1 flex flex-col items-center justify-center text-center px-6 py-16">
    <h2 class="text-4xl font-bold text-white mb-4">
      Fresh cuts, <span class="text-amber-400">every time.</span>
    </h2>
    <p class="text-gray-400 text-lg mb-10 max-w-md">
      Book your next appointment online in seconds. No account needed.
    </p>
    <%= link_to "Book an Appointment", new_booking_path,
        class: "bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 px-10 rounded-xl text-lg transition-colors shadow-lg" %>
  </main>

  <!-- Services -->
  <% if @services.any? %>
    <section class="max-w-5xl mx-auto w-full px-6 pb-16">
      <h3 class="text-lg font-semibold text-gray-400 uppercase tracking-wide mb-6 text-center">Our Services</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <% @services.each do |service| %>
          <div class="bg-gray-800 rounded-xl px-5 py-4 flex items-center justify-between">
            <div>
              <p class="text-white font-medium"><%= service.name %></p>
              <p class="text-gray-400 text-sm"><%= service.duration_minutes %> min</p>
            </div>
            <span class="text-amber-400 font-bold"><%= format_currency(service.base_price) %></span>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- Footer -->
  <footer class="text-center text-gray-600 text-sm pb-6">
    Powered by <span class="text-amber-500">BarberApp</span>
  </footer>

</div>
