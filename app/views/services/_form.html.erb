<%= form_with model: service, local: true, class: "bg-white shadow rounded-lg p-8 space-y-5 max-w-lg" do |f| %>
  <% if service.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% service.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Service Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400", placeholder: "Haircut" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :base_price, "Price", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :base_price, step: "0.01", min: 0,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400",
          placeholder: "15.00" %>
    </div>
    <div>
      <%= f.label :duration_minutes, "Duration (minutes)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :duration_minutes, min: 1,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400" %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "h-4 w-4 text-amber-500 rounded border-gray-300" %>
    <%= f.label :active, "Active (visible for booking)", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit service.new_record? ? "Add Service" : "Save Changes",
        class: "bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-6 rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancel", services_path, class: "text-gray-500 hover:text-gray-700 py-2 px-4" %>
  </div>
<% end %>
