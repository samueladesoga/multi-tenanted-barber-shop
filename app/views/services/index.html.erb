<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Services</h1>
    <%= link_to "Add Service", new_service_path,
        class: "bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors" %>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <% if @services.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Service</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @services.each do |service| %>
            <tr class="<%= service.active? ? '' : 'opacity-50' %>">
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= service.name %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= format_currency(service.base_price) %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= service.duration_minutes %> min</td>
              <td class="px-6 py-4 text-sm">
                <% if service.active? %>
                  <span class="bg-green-100 text-green-700 text-xs font-medium px-2 py-1 rounded">Active</span>
                <% else %>
                  <span class="bg-gray-100 text-gray-500 text-xs font-medium px-2 py-1 rounded">Inactive</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-right space-x-3">
                <%= link_to "Edit", edit_service_path(service), class: "text-amber-600 hover:text-amber-800" %>
                <%= link_to "Delete", service_path(service), data: { turbo_method: :delete, turbo_confirm: "Delete this service?" },
                    class: "text-red-400 hover:text-red-600" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center text-gray-400">
        <p>No services yet.</p>
        <%= link_to "Add your first service", new_service_path, class: "text-amber-500 underline mt-2 inline-block" %>
      </div>
    <% end %>
  </div>
</div>
