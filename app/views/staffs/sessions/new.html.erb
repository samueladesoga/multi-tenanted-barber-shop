<div class="max-w-sm mx-auto mt-12">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900"><%= current_salon&.name || "BarberApp" %></h1>
    <p class="text-gray-500 mt-1">Staff sign in</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name),
      html: { class: "bg-white shadow rounded-lg p-8 space-y-5" }) do |f| %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-400" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "h-4 w-4 text-amber-500 rounded border-gray-300" %>
        <%= f.label :remember_me, class: "text-sm text-gray-600" %>
      </div>
    <% end %>

    <%= f.submit "Sign in", class: "w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
  <% end %>
</div>
