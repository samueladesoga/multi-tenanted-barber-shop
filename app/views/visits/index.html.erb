<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Visit Log</h1>
    <%= link_to "Check In Customer", new_visit_path,
        class: "bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors" %>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <% if @visits.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Service</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Staff</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @visits.each do |visit| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <%= link_to visit.customer.name, customer_path(visit.customer), class: "hover:text-amber-600" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= visit.service.name %></td>
              <td class="px-6 py-4 text-sm text-gray-600">
                <%= format_currency(visit.price_charged) %>
                <% if visit.is_free? %>
                  <span class="ml-1 text-xs bg-amber-100 text-amber-700 px-1 rounded">FREE</span>
                <% elsif visit.discounted? %>
                  <span class="ml-1 text-xs text-gray-400 line-through"><%= format_currency(visit.service.base_price) %></span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= visit.staff.name %></td>
              <td class="px-6 py-4 text-sm text-gray-400"><%= visit.visited_at.strftime("%d %b %Y, %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-6 py-12 text-center text-gray-400">No visits recorded yet.</p>
    <% end %>
  </div>
</div>
