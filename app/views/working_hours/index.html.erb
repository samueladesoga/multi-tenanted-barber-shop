<div class="max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Working Hours</h1>

  <%= form_with url: working_hours_path, method: :patch, local: true do |f| %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase w-32">Day</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Opens At</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Closes At</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Closed</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @working_hours.each do |wh| %>
            <tr class="<%= wh.is_closed? ? 'bg-gray-50' : '' %>">
              <td class="px-6 py-4 text-sm font-medium text-gray-900 capitalize"><%= wh.day_of_week %></td>
              <td class="px-6 py-4">
                <input type="time" name="working_hours[<%= wh.id %>][opens_at]"
                       value="<%= wh.opens_at&.strftime('%H:%M') || '09:00' %>"
                       class="border border-gray-300 rounded px-2 py-1 text-sm focus:ring-2 focus:ring-amber-400 disabled:opacity-50"
                       <%= "disabled" if wh.is_closed? %>>
              </td>
              <td class="px-6 py-4">
                <input type="time" name="working_hours[<%= wh.id %>][closes_at]"
                       value="<%= wh.closes_at&.strftime('%H:%M') || '18:00' %>"
                       class="border border-gray-300 rounded px-2 py-1 text-sm focus:ring-2 focus:ring-amber-400 disabled:opacity-50"
                       <%= "disabled" if wh.is_closed? %>>
              </td>
              <td class="px-6 py-4">
                <input type="checkbox" name="working_hours[<%= wh.id %>][is_closed]" value="1"
                       <%= "checked" if wh.is_closed? %>
                       onchange="toggleDay(this)"
                       class="h-4 w-4 text-amber-500 rounded border-gray-300">
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-6 flex gap-3">
      <%= f.submit "Save Working Hours", class: "bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-6 rounded-lg transition-colors cursor-pointer" %>
      <%= link_to "Skip for now", dashboard_path, class: "text-gray-500 hover:text-gray-700 py-2 px-4" %>
    </div>
  <% end %>
</div>

<script>
function toggleDay(checkbox) {
  const row = checkbox.closest('tr');
  const timeInputs = row.querySelectorAll('input[type="time"]');
  timeInputs.forEach(input => {
    input.disabled = checkbox.checked;
  });
  row.classList.toggle('bg-gray-50', checkbox.checked);
}
</script>
