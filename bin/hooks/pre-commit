#!/usr/bin/env bash
# Pre-commit hook: runs RuboCop and Brakeman on staged Ruby files.
# To skip in an emergency: git commit --no-verify

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Collect staged .rb and .erb files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(rb|erb)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "Running pre-commit checks..."

# ─── RuboCop ────────────────────────────────────────────────────────────────
echo -e "\n${YELLOW}RuboCop${NC}"
if bin/rubocop --no-color -f github $STAGED_FILES; then
  echo -e "${GREEN}✓ RuboCop passed${NC}"
else
  echo -e "${RED}✗ RuboCop failed. Fix the errors above or run: bin/rubocop -a${NC}"
  exit 1
fi

# ─── Brakeman ───────────────────────────────────────────────────────────────
echo -e "\n${YELLOW}Brakeman${NC}"
if bin/brakeman --no-pager --quiet; then
  echo -e "${GREEN}✓ Brakeman passed${NC}"
else
  echo -e "${RED}✗ Brakeman found security warnings. Fix them before committing.${NC}"
  exit 1
fi

echo -e "\n${GREEN}All checks passed.${NC}"
