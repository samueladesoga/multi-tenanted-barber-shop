#!/usr/bin/env bash
# Pre-commit hook: runs RuboCop on staged .rb files and Brakeman on the full app.
# To skip in an emergency: git commit --no-verify

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# RuboCop only understands plain Ruby — collect .rb files only.
# Brakeman scans the full app (including .erb) separately.
STAGED_RB=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.rb$' || true)
STAGED_ANY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(rb|erb)$' || true)

if [ -z "$STAGED_ANY" ]; then
  exit 0
fi

echo "Running pre-commit checks..."

# ─── RuboCop ────────────────────────────────────────────────────────────────
if [ -n "$STAGED_RB" ]; then
  echo -e "\n${YELLOW}RuboCop${NC}"
  if bin/rubocop --no-color -f github $STAGED_RB; then
    echo -e "${GREEN}✓ RuboCop passed${NC}"
  else
    echo -e "${RED}✗ RuboCop failed. Fix the errors above or run: bin/rubocop -a${NC}"
    exit 1
  fi
fi

# ─── Brakeman ───────────────────────────────────────────────────────────────
echo -e "\n${YELLOW}Brakeman${NC}"
if bin/brakeman --no-pager --quiet; then
  echo -e "${GREEN}✓ Brakeman passed${NC}"
else
  echo -e "${RED}✗ Brakeman found security warnings. Fix them before committing.${NC}"
  exit 1
fi

echo -e "\n${GREEN}All checks passed.${NC}"
